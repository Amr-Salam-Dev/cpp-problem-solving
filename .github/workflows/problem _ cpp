// problem 36
int main() {
	double Num1, Num2;
	char OpType;
	cout << "Enter first number: ";
	cin >> Num1;
	cout << "Enter second number: ";
	cin >> Num2;
	cout << "Enter operator type (+, -, *, /): ";
	cin >> OpType;

	if (OpType == '+') {
		cout << "Result: " << Num1 + Num2 << endl;
	}
	else if (OpType == '-') {
		cout << "Result: " << Num1 - Num2 << endl;
	}
	else if (OpType == '*') {
		cout << "Result: " << Num1 * Num2 << endl;
	}
	else if (OpType == '/') {
		if (Num2 != 0) {
			cout << "Result: " << Num1 / Num2 << endl;
		}
		else {
			cout << "Error: Division by zero!" << endl;
		}
	}
	else {
		cout << "Invalid operator type." << endl;
	}
	return 0;
}




